# Server configuration
PORT=8080

# Set to "production" to disable dev logging middleware
NODE_ENV=production

# GitHub Configuration
# Generate a personal access token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=ghp_iVcEwDS8bQ1XMg2x_example

# Default GitHub owner (optional, can be overridden in requests)
GITHUB_OWNER=your-username-or-org

# Default GitHub repository (optional, can be overridden in requests)
GITHUB_REPO=your-repo-name